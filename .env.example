# Environment Variables Template
# Copy this file to .env and fill in your values
# Never commit .env file to Git - GitHub will block it

# API Configuration
VITE_API_URL=https://api.medxclaim.com
VITE_API_KEY=your_api_key_here

# Environment
VITE_ENV=production

# Analytics (optional)
VITE_ANALYTICS_ID=your_google_analytics_id

# Feature Flags
VITE_ENABLE_CONTACT_FORM=true
VITE_ENABLE_CHAT=false

# Firebase Auth Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Comma-separated list of emails that should always have super_admin role
VITE_SUPER_ADMIN_EMAILS=you@medxclaim.com

# ── Brevo Transactional Email (server-side only – never prefix with VITE_) ──
# Used by netlify/functions/contact-autoreply.mjs
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=noreply@medxclaim.com
BREVO_SENDER_NAME=MedXClaim
BREVO_SUPPORT_EMAIL=support@medxclaim.com

# Optional: override the auto-reply function endpoint (defaults to /.netlify/functions/contact-autoreply)
# VITE_CONTACT_AUTOREPLY_ENDPOINT=/.netlify/functions/contact-autoreply
